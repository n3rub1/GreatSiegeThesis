  Name: Recent Foraging near Ottoman Camp
  Icon: {fileID: 21300196, guid: 7810966f0f690954c87305933cabf2b0, type: 3}
  HasInteraction: 0
  interactionType: 3
  Greeting: MARTO 11 LABS
  Day1Dialog:
  - 
