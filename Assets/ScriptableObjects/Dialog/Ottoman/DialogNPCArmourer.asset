  m_Name: DialogNPCArmourer
  m_EditorClassIdentifier: 
  Name: Ahmed
  Icon: {fileID: -2105629146, guid: d556a7f542c7d03429c5a535ce31a084, type: 3}
  HasInteraction: 0
  interactionType: 1
  Greeting: Haytham Lab11
  Day1Dialog: []
  Day2FirstTimeDialog: []
  Day2MetBeforeDialog: []
