  Name: Muhmud
  Icon: {fileID: -2105629146, guid: d556a7f542c7d03429c5a535ce31a084, type: 3}
  HasInteraction: 0
  interactionType: 1
  Greeting: Yahya Lab11
  Day1Dialog: []
  Day2FirstTimeDialog: []
